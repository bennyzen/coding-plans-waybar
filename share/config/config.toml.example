# ~/.config/coding-plans/config.toml
#
# Toggle providers on/off here — the installer regenerates Waybar's module
# blocks + CSS on every run, so a fresh install or a re-install is the only
# action you ever take.

[providers.claude]
enabled = true

[providers.zai]
enabled = true
# api_key_file = "~/.config/coding-plans/zai-key"   # default — chmod 600

# ─── Styling ────────────────────────────────────────────────────────────
# These values are emitted verbatim into the generated
# ~/.config/waybar/style.css block. Per-provider overrides go under
# [providers.<id>.style]; anything unset falls back to [style].

[style]
font_family    = ""              # empty → inherit from the Waybar bar
font_size      = "11px"
font_weight    = ""
letter_spacing = "0.02em"
padding        = "0 8px 0 23px"
margin         = "0 3px"
icon_size      = "13px"
icon_position  = "6px center"    # x y — passed to CSS background-position
# Coloured disc behind the icon. Handy for mono brand logos (e.g. Z.AI's
# black glyph) that disappear against a dark bar. "" disables the backdrop.
icon_bg_color  = ""              # e.g. "#ffffff" for a white disc
icon_bg_padding = "2px"          # ring width around the icon
border_radius  = ""              # e.g. "10px" for a pill shape
color          = "@foreground"   # base text colour (uses the theme's var)
# Per-state appearance.
fresh_opacity     = 0.92
stale_opacity     = 0.4
empty_opacity     = 0.28
critical_color    = "#c9a227"
critical_weight   = "700"
exhausted_color   = "#d24646"
exhausted_weight  = "700"

# Example per-provider override — bump Claude's icon slightly:
# [providers.claude.style]
# icon_size = "15px"

# Example: white disc only behind the Z.AI logo (leave Claude bare).
# [providers.zai.style]
# icon_bg_color = "#ffffff"

# ─── Rest is behaviour, not look ────────────────────────────────────────

[display]
# Per-provider bar segment (Pango markup). Placeholders:
#   {short_pct} {weekly_pct} {plan_tier} {display_name}
bar_format           = "{short_pct}%·{weekly_pct}%"
join                 = "  "
show_empty_providers = false

[behavior]
stale_after_seconds = 300

[thresholds]
critical  = 80
exhausted = 100

[tooltip]
show_progress_bars = true
show_today         = true
show_updated_ago   = true
bar_width          = 10
