#!/usr/bin/env python3
"""Waybar custom-module entry point. Thin loader over coding_plans.bar."""

from __future__ import annotations

import sys
from pathlib import Path

# Look for the package in the installed location first, then the dev layout.
for _candidate in (
    Path.home() / ".local/share/coding-plans-waybar/lib",
    Path(__file__).resolve().parent.parent / "lib",
):
    if (_candidate / "coding_plans" / "__init__.py").is_file():
        sys.path.insert(0, str(_candidate))
        break

from coding_plans.bar import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
