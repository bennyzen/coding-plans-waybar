#!/usr/bin/env python3
"""GTK4/libadwaita popover. Thin loader over coding_plans.popup."""

from __future__ import annotations

import os
import sys
from pathlib import Path

_override = os.environ.get("CODING_PLANS_LIB_DIR")
for _candidate in (
    Path(_override) if _override else None,
    Path.home() / ".local/share/coding-plans-waybar/lib",
    Path(__file__).resolve().parent.parent / "lib",
):
    if _candidate and (_candidate / "coding_plans" / "__init__.py").is_file():
        sys.path.insert(0, str(_candidate))
        break

from coding_plans.popup import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
